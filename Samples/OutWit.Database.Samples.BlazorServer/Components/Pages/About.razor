@page "/about"

<PageTitle>About - WitDatabase Identity</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">About</MudText>

<MudGrid>
    <MudItem xs="12" md="8">
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Large" Color="Color.Primary" />
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">WitDatabase Identity Server Sample</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        ASP.NET Core Identity + OpenIddict + WitDatabase
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body1" Class="mb-4">
                    This sample demonstrates a complete identity server built with WitDatabase as the storage backend.
                    It includes user management, authentication, and OAuth 2.0 / OpenID Connect support.
                </MudText>

                <MudText Typo="Typo.h6" Class="mb-2">Features</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        ASP.NET Core Identity with custom ApplicationUser
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        OpenIddict for OAuth 2.0 / OpenID Connect
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        Role-based authorization (Administrator, User)
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        User management (CRUD operations)
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        WitDatabase with Entity Framework Core
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        Schema initialization via HostedService
                    </MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                        Blazor Server with MudBlazor UI
                    </MudListItem>
                </MudList>
            </MudCardContent>
        </MudCard>

        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Architecture</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudSimpleTable Dense="true" Hover="true" Bordered="true">
                    <thead>
                        <tr>
                            <th>Component</th>
                            <th>Technology</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>UI</td>
                            <td>Blazor Server + MudBlazor</td>
                            <td>Interactive server-side rendering</td>
                        </tr>
                        <tr>
                            <td>Authentication</td>
                            <td>ASP.NET Core Identity</td>
                            <td>User accounts, passwords, roles</td>
                        </tr>
                        <tr>
                            <td>OAuth/OIDC</td>
                            <td>OpenIddict</td>
                            <td>Token issuance and validation</td>
                        </tr>
                        <tr>
                            <td>ORM</td>
                            <td>Entity Framework Core</td>
                            <td>Database abstraction layer</td>
                        </tr>
                        <tr>
                            <td>Database</td>
                            <td>WitDatabase</td>
                            <td>High-performance embedded database</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudCardContent>
        </MudCard>

        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Default Credentials</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText><strong>Email:</strong> admin@example.com</MudText>
                    <MudText><strong>Password:</strong> Admin123!</MudText>
                </MudAlert>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Password Requirements</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Check">Minimum 8 characters</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">At least one uppercase letter</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">At least one lowercase letter</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">At least one digit</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.Check">At least one special character</MudListItem>
                </MudList>
            </MudCardContent>
        </MudCard>

        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Links</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Custom.Brands.GitHub"
                               Href="https://github.com/dmitrat/WitDatabase" Target="_blank">
                        GitHub Repository
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.Description"
                               Href="https://documentation.openiddict.com/" Target="_blank">
                        OpenIddict Docs
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
