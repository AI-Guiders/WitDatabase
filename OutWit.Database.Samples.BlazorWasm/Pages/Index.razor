<div class="card">
    <h3>Quick Start</h3>
    
    <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto;">
@@inject IJSRuntime JSRuntime
@@implements IAsyncDisposable

@@code {
    private WitDatabase? _db;
    
    protected override async Task OnInitializedAsync()
    {
        // Use in-memory storage (fully functional)
        _db = await new WitDatabaseBuilder()
            .WithMemoryStorage()
            .WithBTree()
            .WithTransactions()
            .BuildAsync();
            
        // IndexedDB (experimental - init only)
        // _db = await new WitDatabaseBuilder()
        //     .WithIndexedDbStorage("MyDatabase", JSRuntime)
        //     .WithBTree()
        //     .BuildAsync();
    }
    
    private async Task SaveData(byte[] key, byte[] value)
    {
        await _db!.PutAsync(key, value);
        await _db.FlushAsync();
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_db != null)
            await _db.DisposeAsync();
    }
}
    </pre>
</div>

<div class="card">
    <h3>Async API</h3>
    
    <p>All database operations support async patterns for WASM compatibility:</p>
    
    <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto;">
// Async initialization (required for WASM)
var db = await builder.BuildAsync();

// Async CRUD operations
await db.PutAsync(key, value);
var value = await db.GetAsync(key);
await db.DeleteAsync(key);

// Async iteration
await foreach (var (k, v) in db.ScanAsync(null, null))
{
    // Process records
}

// Async flush & dispose
await db.FlushAsync();
await db.DisposeAsync();
    </pre>
</div>

<div class="card">
    <h3>Supported Features</h3>
    
    <ul>
        <li>? B+Tree storage engine (async init via <code>BuildAsync()</code>)</li>
        <li>? ACID transactions</li>
        <li>? MVCC (Multi-Version Concurrency Control)</li>
        <li>? AES-GCM encryption</li>
        <li>? Secondary indexes</li>
        <li>? LSM-Tree (requires file system, not available in browser)</li>
    </ul>
</div>

