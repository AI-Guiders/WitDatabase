@page "/"

<PageTitle>WitDatabase Blazor WASM Sample</PageTitle>

<div class="card">
    <h1>&#128190; WitDatabase Blazor WASM Sample</h1>
    <p>
        This sample demonstrates using <strong>WitDatabase</strong> in a Blazor WebAssembly application.
        Uses async initialization via <code>BuildAsync()</code> for WASM compatibility.
    </p>
</div>

<div class="card">
    <h3>Features Demonstrated</h3>
    
    <ul>
        <li><strong><a href="crud">CRUD Operations</a></strong> - Basic Create, Read, Update, Delete operations</li>
        <li><strong><a href="transactions">Transactions</a></strong> - Transaction support with commit/rollback</li>
        <li><strong><a href="encryption">Encryption</a></strong> - AES-GCM encryption at rest</li>
    </ul>
</div>

<div class="card">
    <h3>Async Initialization for WASM</h3>
    
    <p>
        Blazor WebAssembly runs in a single-threaded environment where synchronous I/O operations are not available.
        WitDatabase provides <code>BuildAsync()</code> for proper async initialization in WASM scenarios.
    </p>
    
    <h4>Supported Features</h4>
    <ul>
        <li>&#10004; B+Tree storage engine (async init via <code>BuildAsync()</code>)</li>
        <li>&#10004; ACID transactions</li>
        <li>&#10004; MVCC (Multi-Version Concurrency Control)</li>
        <li>&#10004; AES-GCM encryption</li>
        <li>&#10004; Secondary indexes</li>
        <li>&#10008; LSM-Tree (requires file system)</li>
    </ul>
    
    <h4>Browser Support</h4>
    <ul>
        <li>Chrome 80+</li>
        <li>Firefox 75+</li>
        <li>Edge 80+</li>
        <li>Safari 14+</li>
    </ul>
</div>

<div class="card">
    <h3>Quick Start</h3>
    
    <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto;">
@@code {
    private WitDatabase? _db;
    
    protected override async Task OnInitializedAsync()
    {
        // Use BuildAsync for WASM compatibility
        _db = await new WitDatabaseBuilder()
            .WithMemoryStorage()
            .WithBTree()
            .WithTransactions()
            .BuildAsync();
    }
    
    private async Task SaveData(byte[] key, byte[] value)
    {
        await _db!.PutAsync(key, value);
        await _db.FlushAsync();
    }
}
    </pre>
</div>

<div class="card">
    <h3>Validation Events</h3>
    
    <p>
        WitDatabase now supports validation events for custom validation logic.
        Extension packages can subscribe to perform additional validation.
    </p>
    
    <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto;">
var builder = new WitDatabaseBuilder();

// Subscribe to validation event
builder.OnValidating += options =>
{
    if (options.UseLsmTree)
        throw new InvalidOperationException(
            "LSM-Tree not supported in this environment");
};

// Subscribe to store built event  
builder.OnStoreBuilt += store =>
{
    Console.WriteLine($"Store created: {store.ProviderKey}");
};

var db = await builder
    .WithMemoryStorage()
    .WithBTree()
    .BuildAsync();
    </pre>
</div>
