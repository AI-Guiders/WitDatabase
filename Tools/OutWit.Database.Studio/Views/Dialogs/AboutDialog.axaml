<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OutWit.Database.Studio.ViewModels"
        xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
        mc:Ignorable="d"
        d:DesignWidth="420"
        d:DesignHeight="380"
        x:Class="OutWit.Database.Studio.Views.Dialogs.AboutDialog"
        x:DataType="vm:AboutViewModel"
        Title="About WitDatabase Studio"
        Width="420"
        Height="380"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid RowDefinitions="*,Auto" Margin="24">
        
        <StackPanel Grid.Row="0" Spacing="12" HorizontalAlignment="Center">
            
            <!-- Logo -->
            <Border Width="72" Height="72"
                    Background="{DynamicResource SystemAccentColor}"
                    CornerRadius="36"
                    HorizontalAlignment="Center">
                <PathIcon Data="{x:Static ui:StudioIcons.DB_TABLE}"
                          Width="36" Height="36"
                          Foreground="White"/>
            </Border>

            <!-- Product Name -->
            <TextBlock Text="{Binding ProductName}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <!-- Version -->
            <TextBlock HorizontalAlignment="Center"
                       FontSize="13"
                       Foreground="Gray">
                <Run Text="Version"/>
                <Run Text="{Binding Version}"/>
            </TextBlock>

            <!-- Description -->
            <TextBlock Text="{Binding Description}"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="350"/>

            <!-- Links -->
            <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,8,0,0">
                
                <!-- Website -->
                <Button Command="{Binding OpenWebsiteCommand}"
                        Classes="hyperlink"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{x:Static ui:StudioIcons.LINK_WEB}" 
                                  Width="16" Height="16"
                                  Foreground="{DynamicResource SystemAccentColor}"/>
                        <TextBlock Text="{Binding WebsiteUrl}" 
                                   Foreground="{DynamicResource SystemAccentColor}"
                                   TextDecorations="Underline"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- GitHub -->
                <Button Command="{Binding OpenGitHubCommand}"
                        Classes="hyperlink"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{x:Static ui:StudioIcons.LINK_GITHUB}" 
                                  Width="16" Height="16"
                                  Foreground="{DynamicResource SystemAccentColor}"/>
                        <TextBlock Text="GitHub Repository" 
                                   Foreground="{DynamicResource SystemAccentColor}"
                                   TextDecorations="Underline"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- OutWit Ecosystem -->
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Center">
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="Part of OutWit Ecosystem"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    
                    <Button Command="{Binding OpenAuthorCommand}"
                            Classes="hyperlink"
                            HorizontalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{x:Static ui:StudioIcons.LINK_PERSON}" 
                                      Width="14" Height="14"
                                      Foreground="{DynamicResource SystemAccentColor}"/>
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run Text="by Dmitry Ratner — "/>
                                <Run Text="{Binding AuthorUrl}" 
                                     Foreground="{DynamicResource SystemAccentColor}"
                                     TextDecorations="Underline"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Copyright -->
            <TextBlock Text="{Binding Copyright}"
                       HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="Gray"
                       Margin="0,4,0,0"/>

        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="1"
                Content="Close"
                Command="{Binding CloseCommand}"
                Width="100"
                HorizontalAlignment="Center"
                Margin="0,16,0,0"/>
        
    </Grid>

</Window>
