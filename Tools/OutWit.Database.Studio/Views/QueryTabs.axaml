<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OutWit.Database.Studio.ViewModels"
             xmlns:models="using:OutWit.Database.Studio.Models"
             xmlns:query="using:OutWit.Database.Studio.Views.Query"
             xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OutWit.Database.Studio.Views.QueryTabs"
             x:DataType="vm:QueryTabsViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto,*">
        
        <!-- Tab Strip -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                
                <!-- Tab Headers -->
                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:QueryTab">
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="0,0,1,0"
                                        Padding="12,8"
                                        Cursor="Hand"
                                        PointerPressed="OnTabHeaderClick"
                                        Tag="{Binding}">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                                        </Style>
                                    </Border.Styles>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <!-- Modified indicator -->
                                        <PathIcon Data="{x:Static ui:StudioIcons.TAB_MODIFIED}"
                                                  Width="8" Height="8"
                                                  Foreground="{DynamicResource SystemAccentColor}"
                                                  IsVisible="{Binding IsModified}"
                                                  VerticalAlignment="Center"/>
                                        
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"/>
                                        
                                        <Button Width="20"
                                                Height="20"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{ReflectionBinding #Root.DataContext.CloseTabCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Close tab">
                                            <PathIcon Data="{x:Static ui:StudioIcons.TAB_CLOSE}"
                                                      Width="10" Height="10"/>
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="#22000000"/>
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- New Tab Button -->
                <Button Grid.Column="1"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="4"
                        Command="{Binding NewTabCommand}"
                        ToolTip.Tip="New Query Tab (Ctrl+N)">
                    <PathIcon Data="{x:Static ui:StudioIcons.TAB_NEW}"
                              Width="14" Height="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <query:QueryToolbar Grid.Row="1" DataContext="{Binding}"/>

        <!-- Tab Content - QueryEditor -->
        <Grid Grid.Row="2">
            <query:QueryEditor x:Name="Editor" 
                               DataContext="{Binding SelectedTab}"/>

            <!-- Loading Overlay -->
            <Border Background="#80000000"
                    IsVisible="{Binding IsExecuting}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <Border Width="48" Height="48"
                            Background="White"
                            CornerRadius="24">
                        <PathIcon Data="{x:Static ui:StudioIcons.QUERY_EXECUTE}"
                                  Width="24" Height="24"
                                  Foreground="{DynamicResource SystemAccentColor}"/>
                    </Border>
                    <TextBlock Text="Executing query..."
                               Foreground="White"
                               FontSize="16"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</UserControl>
