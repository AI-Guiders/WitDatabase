<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OutWit.Database.Studio.ViewModels"
             xmlns:models="using:OutWit.Database.Studio.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OutWit.Database.Studio.Views.QueryTabs"
             x:DataType="vm:QueryTabsViewModel">

    <Grid RowDefinitions="Auto,*">
        
        <!-- Tab Strip -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                
                <!-- Tab Headers -->
                <ScrollViewer Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:QueryTab">
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="0,0,1,0"
                                        Padding="12,8"
                                        Cursor="Hand"
                                        PointerPressed="OnTabHeaderClick"
                                        Tag="{Binding}">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                                        </Style>
                                    </Border.Styles>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   VerticalAlignment="Center"/>
                                        
                                        <Button Content="×"
                                                FontSize="16"
                                                Width="20"
                                                Height="20"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding $parent[ItemsControl].((vm:QueryTabsViewModel)DataContext).CloseTabCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Close tab">
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="#22000000"/>
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- New Tab Button -->
                <Button Grid.Column="1"
                        Content="+"
                        FontSize="18"
                        Width="32"
                        Height="32"
                        Padding="0"
                        Margin="4"
                        Command="{Binding NewTabCommand}"
                        ToolTip.Tip="New Query Tab (Ctrl+N)"/>
            </Grid>
        </Border>

        <!-- Tab Content -->
        <ContentControl Grid.Row="1"
                        Content="{Binding SelectedTab}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="models:QueryTab">
                    <Grid RowDefinitions="Auto,*,Auto,*">
                        
                        <!-- Toolbar -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                
                                <Button Command="{Binding $parent[ContentControl].((vm:QueryTabsViewModel)DataContext).ExecuteQueryCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="Execute Query (F5)"
                                        Width="100"
                                        Classes="accent">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <PathIcon Data="M8,5.14V19.14L19,12.14L8,5.14Z" 
                                                  Width="14" Height="14"/>
                                        <TextBlock Text="Execute" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Separator Width="1" Height="24"/>

                                <Button Command="{Binding $parent[ContentControl].((vm:QueryTabsViewModel)DataContext).SaveTabCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="Save (Ctrl+S)"
                                        Width="80">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" 
                                                  Width="14" Height="14"/>
                                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding $parent[ContentControl].((vm:QueryTabsViewModel)DataContext).ClearResultsCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="Clear Results"
                                        Width="80">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                                  Width="14" Height="14"/>
                                        <TextBlock Text="Clear" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- SQL Editor -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                Padding="8">
                            <TextBox Name="SqlTextBox"
                                     Text="{Binding SqlText, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas,Courier New"
                                     FontSize="13"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Watermark="Enter SQL query here..."
                                     IsEnabled="True"
                                     Focusable="True"/>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Row="2"
                                      Height="4"
                                      HorizontalAlignment="Stretch"
                                      Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>

                        <!-- Results Area -->
                        <TabControl Grid.Row="3"
                                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                            
                            <!-- Results Tab -->
                            <TabItem Header="Results">
                                <Grid>
                                    <!-- Data Grid for Results -->
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto"
                                                  IsVisible="{Binding HasResults}">
                                        <DataGrid ItemsSource="{Binding ResultDataView}"
                                                  IsReadOnly="True"
                                                  GridLinesVisibility="All"
                                                  BorderThickness="0"
                                                  Background="Transparent"/>
                                    </ScrollViewer>

                                    <!-- No Results Message -->
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="8"
                                                IsVisible="{Binding !HasResults}">
                                        <PathIcon Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z"
                                                  Width="48"
                                                  Height="48"
                                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                                        <TextBlock Text="No results to display"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="Execute a query to see results here"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <!-- Messages Tab -->
                            <TabItem Header="Messages">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="16" Spacing="8">
                                        
                                        <!-- Success Message -->
                                        <Border Background="#D4EDDA"
                                                BorderBrush="#C3E6CB"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12"
                                                IsVisible="{Binding IsSuccess}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="? Query executed successfully"
                                                           FontWeight="SemiBold"
                                                           Foreground="#155724"/>
                                                <TextBlock Foreground="#155724">
                                                    <Run Text="Rows affected:"/>
                                                    <Run Text="{Binding RowsAffected}" FontWeight="Bold"/>
                                                </TextBlock>
                                                <TextBlock Foreground="#155724">
                                                    <Run Text="Execution time:"/>
                                                    <Run Text="{Binding ExecutionTimeMs, StringFormat='{}{0:F2} ms'}" FontWeight="Bold"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Error Message -->
                                        <Border Background="#F8D7DA"
                                                BorderBrush="#F5C6CB"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12"
                                                IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="? Query execution failed"
                                                           FontWeight="SemiBold"
                                                           Foreground="#721C24"/>
                                                <TextBlock Text="{Binding ErrorMessage}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#721C24"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- No Messages -->
                                        <TextBlock Text="No messages"
                                                   FontStyle="Italic"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                                   IsVisible="{Binding !HasMessages}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>

                        <!-- Loading Overlay -->
                        <Border Grid.Row="0" Grid.RowSpan="4"
                                Background="#80000000"
                                IsVisible="{Binding $parent[ContentControl].((vm:QueryTabsViewModel)DataContext).IsExecuting}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="12">
                                <Border Width="48" Height="48"
                                        Background="White"
                                        CornerRadius="24">
                                    <TextBlock Text="..."
                                               FontSize="24"
                                               Foreground="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Executing query..."
                                           Foreground="White"
                                           FontSize="16"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>

</UserControl>
