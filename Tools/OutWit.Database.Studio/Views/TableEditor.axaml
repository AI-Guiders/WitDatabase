<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OutWit.Database.Studio.ViewModels"
             xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
             xmlns:c="using:OutWit.Database.Studio.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OutWit.Database.Studio.Views.TableEditor"
             x:DataType="vm:ApplicationViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Table Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{x:Static ui:StudioIcons.DB_TABLE}"
                                  Width="16" Height="16"
                                  Foreground="{DynamicResource SystemAccentColor}"/>
                        <TextBlock Text="{Binding TableEditorVm.TableName, FallbackValue='No table selected'}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Row count -->
                    <TextBlock VerticalAlignment="Center"
                               Foreground="Gray"
                               IsVisible="{Binding TableEditorVm.TableName, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Run Text="("/>
                        <Run Text="{Binding TableEditorVm.TotalRowCount}"/>
                        <Run Text="rows)"/>
                    </TextBlock>
                    
                    <!-- Changes indicator -->
                    <Border Background="#FFF3CD"
                            BorderBrush="#FFC107"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            IsVisible="{Binding TableEditorVm.HasChanges}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <PathIcon Data="{x:Static ui:StudioIcons.COMMON_WARNING}"
                                      Width="12" Height="12"
                                      Foreground="#856404"/>
                            <TextBlock Text="Unsaved changes"
                                       FontSize="12"
                                       Foreground="#856404"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding TableEditorVm.RefreshCommand}"
                            IsEnabled="{Binding TableEditorVm.CanRefresh}"
                            ToolTip.Tip="Refresh data"
                            Width="32" Height="32"
                            Padding="0">
                        <PathIcon Data="{x:Static ui:StudioIcons.TABLE_STRUCTURE_REFRESH}"
                                  Width="16" Height="16"/>
                    </Button>

                    <Rectangle Width="1"
                               Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                               Margin="4,4"/>

                    <Button Command="{Binding TableEditorVm.AddRowCommand}"
                            IsEnabled="{Binding TableEditorVm.CanAddRow}"
                            ToolTip.Tip="Add new row"
                            Width="32" Height="32"
                            Padding="0">
                        <PathIcon Data="{x:Static ui:StudioIcons.TABLE_EDITOR_ADD_ROW}"
                                  Width="16" Height="16"/>
                    </Button>

                    <Button Command="{Binding TableEditorVm.DeleteRowCommand}"
                            IsEnabled="{Binding TableEditorVm.CanDeleteRow}"
                            ToolTip.Tip="Delete selected row"
                            Width="32" Height="32"
                            Padding="0">
                        <PathIcon Data="{x:Static ui:StudioIcons.TABLE_EDITOR_DELETE_ROW}"
                                  Width="16" Height="16"/>
                    </Button>

                    <Rectangle Width="1"
                               Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                               Margin="4,4"/>

                    <Button Command="{Binding TableEditorVm.CommitCommand}"
                            IsEnabled="{Binding TableEditorVm.CanCommit}"
                            ToolTip.Tip="Commit changes"
                            Width="32" Height="32"
                            Padding="0"
                            Classes="accent">
                        <PathIcon Data="{x:Static ui:StudioIcons.TABLE_EDITOR_COMMIT}"
                                  Width="16" Height="16"/>
                    </Button>

                    <Button Command="{Binding TableEditorVm.RollbackCommand}"
                            IsEnabled="{Binding TableEditorVm.CanRollback}"
                            ToolTip.Tip="Discard changes"
                            Width="32" Height="32"
                            Padding="0">
                        <PathIcon Data="{x:Static ui:StudioIcons.TABLE_EDITOR_ROLLBACK}"
                                  Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Grid Grid.Row="1">
            <!-- Empty State -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding TableEditorVm.TableName, Converter={x:Static ObjectConverters.IsNull}}">
                <Border Width="48" Height="48"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="24"
                        HorizontalAlignment="Center">
                    <PathIcon Data="{x:Static ui:StudioIcons.DB_TABLE}"
                              Width="24" Height="24"
                              Foreground="Gray"/>
                </Border>
                <TextBlock Text="No table selected"
                           FontSize="14"
                           Foreground="Gray"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Double-click a table in the explorer to edit its data"
                           FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Editable DataGrid -->
            <c:EditableDataGrid x:Name="DataGrid"
                                ResultView="{Binding TableEditorVm.CurrentView}"
                                SelectedRowView="{Binding TableEditorVm.SelectedRowView, Mode=TwoWay}"
                                ColumnInfos="{Binding TableEditorVm.Columns}"
                                CellEditedCommand="{Binding TableEditorVm.CellEditedCommand}"
                                BorderThickness="0"
                                Background="Transparent"
                                IsVisible="{Binding TableEditorVm.TableName, Converter={x:Static ObjectConverters.IsNotNull}}"/>

            <!-- Loading Overlay -->
            <Border Background="#80000000"
                    IsVisible="{Binding TableEditorVm.IsLoading}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <Border Width="32" Height="32"
                            Background="White"
                            CornerRadius="16">
                        <PathIcon Data="{x:Static ui:StudioIcons.DB_TABLE}"
                                  Width="16" Height="16"
                                  Foreground="{DynamicResource SystemAccentColor}"/>
                    </Border>
                    <TextBlock Text="Loading data..."
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4"
                IsVisible="{Binding TableEditorVm.TableName, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Error Message -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            IsVisible="{Binding TableEditorVm.ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <PathIcon Data="{x:Static ui:StudioIcons.COMMON_WARNING}"
                              Width="14" Height="14"
                              Foreground="#DC3545"/>
                    <TextBlock Text="{Binding TableEditorVm.ErrorMessage}"
                               Foreground="#DC3545"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Help text when no error -->
                <TextBlock Grid.Column="0"
                           Text="Double-click a cell to edit. Press Enter to confirm, Escape to cancel."
                           Foreground="Gray"
                           FontSize="12"
                           VerticalAlignment="Center"
                           IsVisible="{Binding TableEditorVm.ErrorMessage, Converter={x:Static ObjectConverters.IsNull}}"/>

                <!-- Keyboard shortcuts help -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="16">
                    <TextBlock Text="Ctrl+S: Commit"
                               Foreground="Gray"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Del: Delete row"
                               Foreground="Gray"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</UserControl>
